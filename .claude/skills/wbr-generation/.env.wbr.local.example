# Copie de ce fichier -> .env.wbr.local (jamais committé).
# En routine cloud, setup.sh écrit ce fichier automatiquement depuis les
# variables d'environnement du même nom (Settings > Environment variables).
WBR_DATABASE_URL=postgresql://analyst_wbr:CHANGE_ME@host:5432/db?sslmode=require
WBR_ENDPOINT_URL=https://example.com/wbr
WBR_ENDPOINT_TOKEN=CHANGE_ME
